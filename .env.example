# Configuración de Base de Datos (Supabase / PostgreSQL)
# Para desarrollo local se puede dejar vacío y se creará automáticamente una base de datos SQLite (gastos.db)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Secreto JWT para codificar tokens (genera una cadena larga y aleatoria)
JWT_SECRET=supersecretjwtkeyforgastospersonales123!
